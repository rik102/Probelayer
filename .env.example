# Probelayer model configuration
# Copy this to `.env` and paste your Gemini API key into the key field.

# Gemini OpenAI-compatible endpoint for screenshot + DOM analysis.
OPENAI_COMPAT_CHAT_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions

# Paste your Gemini API key here.
OPENAI_COMPAT_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# Primary multimodal model for analysis.
VISION_MODEL=gemini-3.5-flash

# Optional timeout for Playwright page capture, in milliseconds.
PLAYWRIGHT_TIMEOUT_MS=20000
